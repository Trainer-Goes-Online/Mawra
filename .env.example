# ============================================================
# Coach Mawra — environment variables
# Copy this file to ".env.local" and fill in the values.
# .env.local is gitignored and never committed.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser (not a secret).
# After editing env vars you must restart `npm run dev` (or redeploy).
# ============================================================


# ------------------------------------------------------------
# 1) FREE FUNNEL — REQUIRED for the site to work
# ------------------------------------------------------------

# Mawra's public Calendly scheduling URL (used by the /book-a-call page).
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/assessment-call

# Lead → Google Sheet webhook. The popup lead form (/api/lead) POSTs each lead
# here. Use EITHER:
#   a) a Google Apps Script Web App /exec URL  (deploy apps-script/LeadIntake.gs), OR
#   b) a Pabbly Connect "Webhook" URL.
# Either one appends one row per lead to the CRM Google Sheet.
# If blank, falls back to PABBLY_WEBHOOK_URL below; if both blank, leads are
# accepted but NOT saved (a warning is logged).
LEAD_WEBHOOK_URL=

# Optional legacy webhook (also used by the old paid flow). Used as the fallback
# for LEAD_WEBHOOK_URL if that is blank.
PABBLY_WEBHOOK_URL=


# ------------------------------------------------------------
# 2) ANALYTICS
# ------------------------------------------------------------
# Google Analytics 4 and Microsoft Clarity IDs are hardcoded in app/layout.tsx
# (GA_ID / CLARITY_ID) — no env vars needed.


# ------------------------------------------------------------
# 3) META PIXEL + CONVERSIONS API — optional (for Facebook/Instagram ads)
# ------------------------------------------------------------

# Pixel / dataset ID. Read server-side and rendered into the page by layout.tsx,
# then handed to the browser pixel. (Pixel IDs aren't secrets.)
META_PIXEL_ID=

# CAPI access token — SERVER-ONLY secret. Events Manager → Settings →
# Conversions API → Generate access token. Never expose.
META_CAPI_ACCESS_TOKEN=

# Optional — Events Manager Test Events code. Set ONLY while QA-ing; blank in prod.
META_TEST_EVENT_CODE=

# Free-registration CAPI event names, fired server-side when the lead form is
# submitted (both go to Meta in one call). Spaces in the standard name are
# stripped so "Complete Registration" -> "CompleteRegistration".
FREE_STANDARD_EVENT=Complete Registration
FREE_CUSTOM_EVENT=FreeLeadRegistration


# ------------------------------------------------------------
# 4) RAZORPAY — optional, kept for a future paid flow
# (Not used by the current FREE funnel. The /checkout route + /api/razorpay/*
#  routes remain in the codebase so a paid offer can be switched on later.)
# ------------------------------------------------------------

# Public Key ID — safe to expose; the Razorpay checkout modal needs it client-side.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Secret — NEVER expose. Creates orders + verifies the HMAC payment signature.
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Price in paise (₹97 = 9700). Single source of truth for the displayed price.
RAZORPAY_AMOUNT_PAISE=9700
RAZORPAY_CURRENCY=INR
